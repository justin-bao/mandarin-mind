{
  "name": "mandarin-mind-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo/AppEntry.js",
  "scripts": {
    "env:local": "cp .env.localdev .env.local",
    "env:prod": "cp .env.production .env.local",
    "start": "expo start",
    "start:local": "npm run env:local && expo start",
    "start:prod": "npm run env:prod && expo start",
    "ios": "expo run:ios",
    "ios:local": "npm run env:local && expo run:ios",
    "ios:local:device": "npm run env:local && expo run:ios --device",
    "ios:prod": "npm run env:prod && expo run:ios --configuration Release",
    "ios:prod:device": "npm run env:prod && expo run:ios --device --configuration Release",
    "android": "expo run:android",
    "android:local": "npm run env:local && expo run:android",
    "android:prod": "npm run env:prod && expo run:android --variant release",
    "web": "expo start --web",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.4",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/netinfo": "^11.4.1",
    "@supabase/supabase-js": "^2.105.3",
    "@tanstack/react-query": "^5.60.5",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-av": "~15.0.2",
    "expo-document-picker": "~13.0.3",
    "expo-image-picker": "~16.0.6",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-safe-area-context": "4.12.0",
    "react-native-url-polyfill": "^2.0.0"
  },
  "devDependencies": {
    "@types/react": "~18.3.12",
    "typescript": "~5.3.3"
  }
}
